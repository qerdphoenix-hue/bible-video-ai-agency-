# ============================================
# ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# OPENAI API CONFIGURATION
# ============================================
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7

# ============================================
# TEXT-TO-SPEECH CONFIGURATION
# ============================================
# Options: elevenlabs, google, azure
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Rachel (default)
ELEVENLABS_MODEL_ID=eleven_monolingual_v1

# Google Cloud TTS
GOOGLE_TTS_PROJECT_ID=your_project_id
GOOGLE_TTS_CREDENTIALS_PATH=/path/to/credentials.json

# Azure Speech
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastus

# ============================================
# VIDEO GENERATION CONFIGURATION
# ============================================
# Options: did, synthesia, runway
VIDEO_PROVIDER=did
DID_API_KEY=your_did_api_key_here
DID_AVATAR_ID=default

# Synthesia
SYNTHESIA_API_KEY=your_synthesia_api_key_here
SYNTHESIA_AVATAR_ID=default

# Runway ML
RUNWAY_API_KEY=your_runway_api_key_here

# ============================================
# SOCIAL MEDIA PLATFORMS
# ============================================

# YouTube
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CLIENT_ID=your_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_REFRESH_TOKEN=your_refresh_token

# TikTok
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
TIKTOK_REFRESH_TOKEN=your_tiktok_refresh_token
TIKTOK_CLIENT_ID=your_tiktok_client_id
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# Instagram
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id
INSTAGRAM_USER_ID=your_user_id

# Twitter/X
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/bible_ai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_ECHO=False

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_DECODE_RESPONSES=True

# ============================================
# CELERY CONFIGURATION
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json

# ============================================
# SCHEDULING CONFIGURATION
# ============================================
SCHEDULER_ENABLED=True
SCHEDULER_INTERVAL_HOURS=24
SCHEDULER_MAX_VIDEOS_PER_DAY=3
SCHEDULER_TIMEZONE=America/New_York

# ============================================
# APPLICATION CONFIGURATION
# ============================================
APP_NAME=Bible Video AI Agency
APP_VERSION=1.0.0
APP_ENV=development  # development, staging, production
DEBUG=True
LOG_LEVEL=INFO

# ============================================
# API CONFIGURATION
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=True
API_KEY_REQUIRED=True
API_RATE_LIMIT=100/minute

# ============================================
# AWS CONFIGURATION (Optional)
# ============================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=bible-video-ai-bucket

# ============================================
# GOOGLE CLOUD CONFIGURATION (Optional)
# ============================================
GCP_PROJECT_ID=your_gcp_project_id
GCP_CREDENTIALS_PATH=/path/to/gcp-credentials.json

# ============================================
# SENTRY ERROR TRACKING (Optional)
# ============================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_password
SMTP_FROM_ADDRESS=noreply@biblevideoai.com